"""vfam_trees Snakemake workflow.

This file is invoked by the vfam_trees CLI and should not be run directly.
Required config keys (passed via --config):
    families      : list of family names
    global_config : path to global.yaml
    configs_dir   : path to per-family configs directory
    output_dir    : results directory
    log_level     : DEBUG | INFO | WARNING
    threads       : threads per family job
"""
from pathlib import Path
import json


# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------
FAMILIES     = config["families"]
GLOBAL_CFG   = config["global_config"]
CONFIGS_DIR  = config["configs_dir"]
OUTPUT_DIR   = config["output_dir"]
LOG_LEVEL    = config.get("log_level", "INFO")
THREADS      = config.get("threads", 1)


def family_done(family):
    # Sentinel written by the pipeline when a family finishes (done or skipped).
    sentinel = Path(OUTPUT_DIR) / f".done_{family}"
    return sentinel.exists()


def pending_families():
    return [f for f in FAMILIES if not family_done(f)]


PENDING = pending_families()

if not PENDING:
    print("All families already processed. Use --forcerun or delete .done_<family> to rerun.")


# ---------------------------------------------------------------------------
# Target rule
# ---------------------------------------------------------------------------
rule all:
    input:
        expand(
            "{output_dir}/.done_{family}",
            output_dir=OUTPUT_DIR,
            family=PENDING,
        )


# ---------------------------------------------------------------------------
# Per-family rule: runs the full Python pipeline for one family
# ---------------------------------------------------------------------------
rule run_family:
    output:
        sentinel = "{output_dir}/.done_{family}",
    threads: THREADS
    run:
        from vfam_trees.pipeline import run_family
        run_family(
            family=wildcards.family,
            global_config_path=Path(GLOBAL_CFG),
            configs_dir=Path(CONFIGS_DIR),
            output_dir=Path(OUTPUT_DIR),
            threads=threads,
            log_level=LOG_LEVEL,
            summary_path=Path(OUTPUT_DIR) / "summary.tsv",
        )
